#!/usr/bin/env bash
# Hotkey handler: "click the most recent Claude Code notification banner".
# Instead of trying to programmatically click the macOS banner (fragile UI
# scripting), we read the most recent route file and invoke cc-focus.sh
# directly. Result: same effect as clicking, but works even if the banner
# has auto-dismissed.

# Debug ping so we can verify Karabiner is actually invoking us.
printf '[%s] cc-banner-click invoked\n' "$(date +%T)" >> /tmp/cc-banner-click.log

# Find the most recent route file whose alerter is STILL running — i.e., a
# banner that's currently displayed. Skip stale routes for banners that
# already timed out or were dismissed.
session_id=""
for route in $(ls -t /tmp/cc-notify/*.route 2>/dev/null); do
  candidate_sid=$(basename "$route" .route)
  if pgrep -f "alerter.*cc-$candidate_sid" >/dev/null 2>&1; then
    session_id="$candidate_sid"
    break
  fi
done

if [ -z "$session_id" ]; then
  # No live banner — hotkey is a no-op.
  exit 2
fi

# Try the plugin-installed focus script first; fall back to manual install path.
focus_rc=2
for candidate in \
  ~/.claude/plugins/cache/farishijazi-plugins/cc-notify/*/hooks/cc-focus.sh \
  ~/projects/claude-plugins/plugins/cc-notify/hooks/cc-focus.sh \
  ~/.claude/hooks/cc-focus.sh; do
  if [ -x "$candidate" ]; then
    bash "$candidate" "$session_id"
    focus_rc=$?
    break
  fi
done

# Dismiss the banner only if focus actually succeeded.
if [ "$focus_rc" = "0" ]; then
  # alerter --remove takes the group id; cc-notify groups as "cc-<session_id>".
  alerter_bin=$(command -v alerter 2>/dev/null || echo /opt/homebrew/bin/alerter)
  if [ -x "$alerter_bin" ]; then
    "$alerter_bin" --remove "cc-$session_id" >/dev/null 2>&1 &
  fi
  # Belt-and-suspenders: kill the alerter process that's blocking on this group.
  pkill -f "alerter.*cc-$session_id" 2>/dev/null
fi

exit "$focus_rc"
